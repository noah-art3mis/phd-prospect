# n8n runtime
N8N_ENCRYPTION_KEY=replace-with-a-long-random-value
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Mexico_City

# One-time Notion bootstrap
NOTION_TOKEN=replace-with-notion-integration-token
NOTION_PARENT_PAGE_ID=replace-with-shared-parent-page-id

# Values configured as n8n credentials after startup
TELEGRAM_ALLOWED_USER_ID=replace-with-your-telegram-user-id
