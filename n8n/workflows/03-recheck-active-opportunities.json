{
  "connections": {
    "Build recheck request": {
      "main": [
        [
          {
            "index": 0,
            "node": "Re-extract status",
            "type": "main"
          }
        ]
      ]
    },
    "Diff and alert": {
      "main": [
        [
          {
            "index": 0,
            "node": "Has alert",
            "type": "main"
          },
          {
            "index": 0,
            "node": "Update last checked",
            "type": "main"
          }
        ]
      ]
    },
    "Fetch source": {
      "main": [
        [
          {
            "index": 0,
            "node": "Build recheck request",
            "type": "main"
          }
        ]
      ]
    },
    "Has alert": {
      "main": [
        [
          {
            "index": 0,
            "node": "Send alert",
            "type": "main"
          }
        ]
      ]
    },
    "Prepare opportunities": {
      "main": [
        [
          {
            "index": 0,
            "node": "Fetch source",
            "type": "main"
          }
        ]
      ]
    },
    "Query active opportunities": {
      "main": [
        [
          {
            "index": 0,
            "node": "Prepare opportunities",
            "type": "main"
          }
        ]
      ]
    },
    "Re-extract status": {
      "main": [
        [
          {
            "index": 0,
